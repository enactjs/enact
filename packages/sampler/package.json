    "@enact/storybook-utils": "^8.0.0",
    "@enact/ui": "^5.5.1",
    "@enact/webos": "^5.5.1",
    "@github-ui/storybook-addon-performance-panel": "^1.1.4",
    "@storybook/react-vite": "^10.4.4",
    "classnames": "^2.5.1",
    "ilib": "^14.22.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "storybook": "^10.4.4"
  }
